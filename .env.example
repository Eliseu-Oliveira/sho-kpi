# Copie este arquivo para ".env" na raiz do projeto e preencha com os
# valores do seu projeto Supabase (Project Settings → API).
#
#   cp .env.example .env
#
# IMPORTANTE: o arquivo .env nunca deve ser commitado no Git nem
# enviado para ninguém — ele fica de fora do controle de versão
# graças ao .gitignore. No Netlify, configure essas mesmas variáveis
# em Site settings → Environment variables (não suba o .env lá).

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-public-aqui
